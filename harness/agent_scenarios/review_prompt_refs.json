{
  "scenario_id": "review_prompt_refs",
  "version": "1.0",
  "description": "Read-only review of a run that checks image_prompts / video_prompts reference real characters / locations / props from the bibles.",
  "category": "review",
  "risk_level": "read_only",
  "expected_outcome": "agent_review",
  "expected_evidence_min_count": 3,
  "preconditions": {
    "run_dir_must_exist": true,
    "image_prompts_must_exist": true,
    "character_bible_must_exist": true,
    "agent_must_not_trigger_run": true
  },
  "input": {
    "run_dir": "<run_dir>",
    "checks": [
      "every_image_prompt_references_real_character_or_location",
      "every_video_prompt_mentions_motion_camera_avoid",
      "no_unresolved_placeholder_in_prompt",
      "shot_id_alignment_between_shot_list_and_prompts"
    ]
  },
  "expected_tool_calls": [
    {
      "tool": "read_run_summary",
      "expected_status": "ok"
    },
    {
      "tool": "list_artifacts",
      "expected_status": "ok"
    },
    {
      "tool": "read_artifact",
      "expected_status": "ok",
      "must_contain_keys": [
        "image_prompts",
        "video_prompts"
      ]
    },
    {
      "tool": "read_artifact",
      "expected_status": "ok",
      "must_contain_keys": [
        "character_bible",
        "location_bible",
        "prop_bible"
      ]
    }
  ],
  "forbidden_tool_calls": [
    "run_pipeline",
    "run_batch",
    "rebuild_prompts",
    "submit_paid_job",
    "execute_arbitrary_shell"
  ],
  "expected_approval_requests": [],
  "assertions": [
    "every review finding cites a specific artifact path + line/id",
    "no natural-language claim without an EvidenceRef",
    "no write actions executed",
    "review_version field present and equals 1.0"
  ]
}

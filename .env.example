# Planner environment overrides.
# Copy to `.env.development` or `.env.production` for real overrides.
# Never commit files containing real secrets.

PLANNER_ENV=development
PLANNER_CONFIG_PATH=config/development.json
PLANNER_LOG_LEVEL=DEBUG

# Example of an override variable. Real API keys must NOT be committed.
# PLANNER_OPENAI_API_KEY=replace-me